# Local dev: a plain SQLite file, no external account needed.
# Production (e.g. Vercel): a Turso database URL, e.g. "libsql://<db-name>-<org>.turso.io"
DATABASE_URL="file:./dev.db"

# Only required when DATABASE_URL is a remote libsql:// URL (Turso). Leave unset for local dev.
DATABASE_AUTH_TOKEN=

GEMINI_API_KEY=
